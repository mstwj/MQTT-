<!-- Views/Shared/_Layout.cshtml -->
@{
    
}
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"] - AiLoT智控节能智慧能源管理系统</title>
    <link rel="stylesheet" href="~/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/font-awesome.min.css" />
    <script src="~/css/chart.umd.min.js"></script>

    <style>
        /* 全局滚动条样式 - 不滚动时隐藏 */
        html {
            scrollbar-width: thin;
            scrollbar-color: transparent transparent;
            transition: scrollbar-color 0.3s ease;
        }
        
        html::-webkit-scrollbar {
            width: 8px;
        }
        
        html::-webkit-scrollbar-track {
            background: transparent;
        }
        
        html::-webkit-scrollbar-thumb {
            background: transparent;
            border-radius: 4px;
            transition: background 0.3s ease;
        }
        
        /* 滚动时显示滚动条 */
        html.scrolling {
            scrollbar-color: #c1c1c1 #f1f1f1;
        }
        
        html.scrolling::-webkit-scrollbar-thumb {
            background: #c1c1c1;
        }
        
        html.scrolling::-webkit-scrollbar-thumb:hover {
            background: #a8a8a8;
        }
        
        .page-container {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* 顶部导航基础样式 */
        .header {
            background-color: #007bff;
            color: white;
            padding: 1rem;
            gap: 1rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            height: auto;
        }

        .header-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            width: 100%;
            margin-bottom: 1rem;
        }

        .header-title {
            text-align: center;
            flex: 1;
        }

            .header-title h1 {
                margin-bottom: 0;
                font-size: 1.5rem;
            }

        .user-info {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        /* 侧边栏样式 */
        .sidebar {
            background-color: #f8f9fa;
            border-right: 1px solid #dee2e6;
            padding: 1rem 0;
            height: calc(100vh - 100px);
            overflow-y: auto;
            transition: all 0.3s ease;
            width: 240px;
            position: fixed;
            left: -240px;
            z-index: 998;
            top: 100px;
        }

            .sidebar.show {
                left: 0;
            }

        /* 唤醒按钮 - 始终可见的小按钮 */
        .sidebar-wakeup {
            background-color: #007bff;
            color: white;
            border: none;
            width: 20px;
            height: 40px;
            border-radius: 0 4px 4px 0;
            cursor: pointer;
            position: fixed;
            left: 0;
            top: 100px;
            z-index: 999;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
            font-size: 0.8rem;
            box-shadow: 2px 0 5px rgba(0,0,0,0.1);
        }

            .sidebar-wakeup:hover {
                width: 25px;
                background-color: #0056b3;
            }

            .sidebar-wakeup i {
                transition: all 0.3s ease;
            }

        /* 提示工具样式 */
        .sidebar-tooltip {
            position: fixed;
            left: 25px;
            top: 120px;
            background-color: #333;
            color: white;
            padding: 5px 10px;
            border-radius: 4px;
            font-size: 12px;
            white-space: nowrap;
            z-index: 1000;
            opacity: 0;
            transform: translateX(-10px);
            transition: all 0.3s ease;
            pointer-events: none;
        }

            .sidebar-tooltip::before {
                content: '';
                position: absolute;
                left: -5px;
                top: 50%;
                transform: translateY(-50%);
                border-width: 5px 5px 5px 0;
                border-style: solid;
                border-color: transparent #333 transparent transparent;
            }

        .sidebar-wakeup:hover + .sidebar-tooltip {
            opacity: 1;
            transform: translateX(0);
        }

        /* 菜单核心样式 */
        .menu-item {
            padding: 0.75rem 1.5rem;
            display: flex;
            align-items: center;
            color: #333;
            text-decoration: none;
            transition: all 0.3s;
        }

            .menu-item .icon-wrap {
                width: 1.25rem;
                text-align: center;
                margin-right: 0.5rem;
            }

            .menu-item:hover, .menu-item.active {
                background-color: #007bff;
                color: white;
            }

        /* 内容区样式 */
        .content {
            padding: 1.5rem;
            overflow-y: auto;
            flex: 1;
            transition: margin-left 0.3s ease;
            padding-top: 70px;
            margin-left: 0;
        }

        .sidebar.show + .content {
            margin-left: 240px;
        }

        /* 自定义图标 */
        .icon-simulation {
            font-family: "FontAwesome";
            width: 1.25rem;
            text-align: center;
            margin-right: 0.5rem;
            display: inline-block;
        }

            .icon-simulation::before {
                content: "\f201";
            }

        .content-max-width {
            max-width: 1400px;
            margin: 0 auto;
        }

        /* 响应式调整 */
        @@media (max-width: 767px) {
            .header-top {
                flex-direction: column;
                gap: 1rem;
            }

            .header-title {
                order: 1;
            }

            .user-info {
                order: 2;
                justify-content: center;
            }

            .header-title h1 {
                font-size: 1.25rem;
            }

            .sidebar {
                top: 140px;
                height: calc(100vh - 140px);
            }

            .sidebar-wakeup {
                top: 150px;
            }

            .sidebar-tooltip {
                top: 150px;
            }

            .content {
                padding-top: 160px;
            }
        }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>
