    <!-- 核心脚本 -->
    <script src="~/css/jquery.min.js"></script>
    <script src="~/css/bootstrap.bundle.min.js"></script>
    <script>
        $(function () {
            const sidebar = $("#sidebar");
            const sidebarWakeup = $("#sidebarWakeup");
            const sidebarToggleInner = $("#sidebarToggleInner");
            const content = $(".content");

            // 显示侧边栏
            function showSidebar() {
                sidebar.addClass("show");
                sidebarWakeup.find("i").removeClass("fa-bars").addClass("fa-chevron-left");
            }

            // 隐藏侧边栏
            function hideSidebar() {
                sidebar.removeClass("show");
                sidebarWakeup.find("i").removeClass("fa-chevron-left").addClass("fa-bars");
            }

            // 1. 点击唤醒按钮显示侧边栏
            sidebarWakeup.on("click", function (e) {
                e.stopPropagation();
                const isShown = sidebar.hasClass("show");

                if (isShown) {
                    hideSidebar();
                } else {
                    showSidebar();
                }
            });

            // 2. 点击内部关闭按钮隐藏侧边栏
            sidebarToggleInner.on("click", function (e) {
                e.stopPropagation();
                hideSidebar();
            });

            // 3. 点击内容区隐藏侧边栏
            content.on("click", function () {
                if (sidebar.hasClass("show")) {
                    hideSidebar();
                }
            });

            // 4. 窗口缩放时保持侧边栏状态
            $(window).resize(function () {
                // 保持当前状态，不需要额外处理
            });
            
            // 5. 滚动时隐藏/显示顶部导航栏，并控制滚动条显示
            let lastScrollTop = 0;
            let scrollTimer = null;
            
            // 处理滚动条显示/隐藏的函数
            function handleScrollbarVisibility() {
                // 添加scrolling类以显示滚动条
                $('html').addClass('scrolling');
                
                // 清除之前的定时器
                if (scrollTimer) {
                    clearTimeout(scrollTimer);
                }
                
                // 设置定时器，在停止滚动100ms后隐藏滚动条
                scrollTimer = setTimeout(function() {
                    $('html').removeClass('scrolling');
                }, 100);
            }
            
            $(window).scroll(function () {
                const scrollTop = $(this).scrollTop();
                const header = $("header.header");
                
                // 处理滚动条可见性
                handleScrollbarVisibility();
                
                // 向上滚动时显示顶部导航栏
                if (scrollTop < lastScrollTop) {
                    header.css({
                        transform: 'translateY(0)',
                        transition: 'transform 0.3s ease'
                    });
                } else if (scrollTop > 50) {
                    // 向下滚动且超过50px时隐藏顶部导航栏
                    header.css({
                        transform: 'translateY(-100%)',
                        transition: 'transform 0.3s ease'
                    });
                }
                
                lastScrollTop = scrollTop;
            });
            
            // 页面加载完成后初始化状态
            $(window).on('load', function() {
                // 默认隐藏滚动条
                $('html').removeClass('scrolling');
                
                // 默认隐藏顶部导航栏
                const header = $("header.header");
                header.css({
                    transform: 'translateY(-100%)',
                    transition: 'transform 0.3s ease'
                });
            });
            
            // 页面DOM加载完成后立即执行，确保初始状态正确
            $(document).ready(function() {
                // 默认隐藏滚动条
                $('html').removeClass('scrolling');
                
                // 默认隐藏顶部导航栏
                const header = $("header.header");
                header.css({
                    transform: 'translateY(-100%)',
                    transition: 'transform 0.3s ease'
                });
            });
        });
    </script>
    @RenderSection("Scripts", required: false)
    <script src="~/css/jquery.validate.min.js"></script>
    <script src="~/css/jquery.validate.unobtrusive.min.js"></script>
</body>
