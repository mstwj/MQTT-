<Window x:Class="MQTT客户端.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MQTT客户端"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 连接区 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0 0 0 10">
            <TextBox x:Name="txtBroker" Text="8.138.205.184" Width="150" Margin="0 0 5 0" />
            <TextBox x:Name="txtPort" Text="1883" Width="60" Margin="0 0 5 0"/>
            <TextBox x:Name="txtClientId" Text="TWJClient" Width="120" Margin="0 0 5 0"/>
            <Button x:Name="btnConnect" Content="连接" Click="btnConnect_Click" Width="80" Margin="0 0 5 0"/>
            <Button x:Name="btnDisconnect" Content="断开" Click="btnDisconnect_Click" Width="80" IsEnabled="False"/>
        </StackPanel>

        <!-- 订阅区 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0 0 0 10">
            <TextBox x:Name="txtSubscribeTopic" Text="hunbu/telemetry" Width="200" Margin="0 0 5 0" />
            <Button x:Name="btnSubscribe" Content="订阅" Click="btnSubscribe_Click" Width="80" Margin="0 0 5 0"/>
        </StackPanel>

        <!-- 日志区 -->
        <ListBox Grid.Row="2" x:Name="lstLog" Margin="0 0 0 10"/>

        <!-- 发布区 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal">
            <TextBox x:Name="txtPublishTopic" Text="test/wpf" Width="200" Margin="0 0 5 0" />
            <TextBox x:Name="txtPublishPayload" Text="Hello MQTT!" Width="300" Margin="0 0 5 0" />
            <Button x:Name="btnPublish" Content="发布" Click="btnPublish_Click" Width="80"/>
        </StackPanel>
    </Grid>
</Window>
